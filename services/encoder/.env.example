# Worker d'encodage — copier vers .env (non commité) pour un lancement hors Docker.
# Avec docker-compose, ces valeurs sont injectées par le compose racine.

SUPABASE_URL=http://127.0.0.1:56321
SUPABASE_SERVICE_ROLE_KEY=<affiché par `supabase status`>

S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=worimo-local
S3_SECRET_ACCESS_KEY=worimo-local-secret
STAGING_BUCKET=worimo-staging
PUBLIC_BUCKET=worimo-public
PUBLIC_BASE_URL=http://localhost:9000/worimo-public

POLL_INTERVAL_MS=5000
MAX_ATTEMPTS=3
