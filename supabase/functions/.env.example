# Secrets des Edge Functions — copier vers supabase/functions/.env (non commité)
# puis : supabase functions serve --env-file supabase/functions/.env
#
# ---- Développement local (MinIO via docker-compose) ----
# L'edge runtime tourne dans Docker : il joint MinIO via host.docker.internal.
# Le navigateur/l'app joint MinIO via localhost (URLs présignées).
R2_ENDPOINT_PUBLIC=http://localhost:9000
R2_ENDPOINT_INTERNAL=http://host.docker.internal:9000
R2_ACCESS_KEY_ID=worimo-local
R2_SECRET_ACCESS_KEY=worimo-local-secret
R2_STAGING_BUCKET=worimo-staging
R2_PUBLIC_BUCKET=worimo-public
R2_PUBLIC_BASE_URL=http://localhost:9000/worimo-public

# ---- Production (Cloudflare R2) — à définir via `supabase secrets set` ----
# R2_ENDPOINT_PUBLIC=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ENDPOINT_INTERNAL=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=<clé API R2>
# R2_SECRET_ACCESS_KEY=<secret API R2>
# R2_STAGING_BUCKET=worimo-staging
# R2_PUBLIC_BUCKET=worimo-public
# R2_PUBLIC_BASE_URL=https://media.worimo.com   # domaine public branché sur le bucket
